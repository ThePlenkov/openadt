{
  "name": "devcontainer-bootstrap",
  "root": "tools/devcontainer-bootstrap",
  "sourceRoot": "tools/devcontainer-bootstrap/src",
  "projectType": "application",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx tsc -p tools/devcontainer-bootstrap/tsconfig.json --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx tsc -p tools/devcontainer-bootstrap/tsconfig.json --noEmit"
      }
    },
    "prepare": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun tools/devcontainer-bootstrap/src/main.ts"
      }
    }
  }
}
