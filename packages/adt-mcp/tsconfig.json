{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2024"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@openadt/adt-infra": ["../../packages/adt-infra/src/index.ts"],
      "@openadt/adt-config": ["../../packages/adt-config/src/index.ts"],
      "@openadt/adt-lsp-client": ["../../packages/adt-lsp-client/src/index.ts"],
      "@openadt/adt-lsp-mcp-tools": ["../../packages/adt-lsp-mcp-tools/src/index.ts"],
      "@openadt/mcp-framing": ["../../packages/mcp-framing/src/index.ts"]
    },
    "ignoreDeprecations": "6.0",
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/cli/**",
    "src/mcp-dev-stdio-bin.ts",
    "src/openadt-mcp-bin.ts",
    "src/main.ts",
    "src/test-mcp-stdio.ts",
    "src/mcp/stdio-proxy.ts",
    "src/mcp/stdio-proxy.test.ts"
  ]
}
