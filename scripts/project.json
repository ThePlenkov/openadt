    "act-debt-query": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun scripts/act/review-debt-cli.ts query"
      }
    },
    "act-debt-plan": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun scripts/act/review-debt-cli.ts plan"
      }
    },
    "act-debt-done": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun scripts/act/review-debt-cli.ts done"
      }
    },
    "act-debt-test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun scripts/act/review-debt-cli.ts test"
      }
