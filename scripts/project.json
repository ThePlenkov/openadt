{
  "name": "scripts",
  "root": "scripts",
  "projectType": "library",
  "targets": {
    "act-debt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun scripts/act/review-debt-cli.ts"
      }
    },
    "act-debt-harvest": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun scripts/act/review-debt-cli.ts harvest"
      }
    },
    "act-debt-harvest-pr": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun scripts/act/review-debt-cli.ts harvest-pr"
      }
