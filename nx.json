{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "tui": {
    "enabled": false
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  },
  "namedInputs": {
    "sharedGlobals": ["{workspaceRoot}/.github/workflows/ci.yml"],
    "default": ["sharedGlobals"],
    "javaSources": [
      "{projectRoot}/pom.xml",
      "{projectRoot}/src/**/*",
      "{projectRoot}/mvnw",
      "{projectRoot}/mvnw.cmd",
      "{projectRoot}/.mvn/**/*"
    ],
    "javaMonorepoSources": [
      "{workspaceRoot}/pom.xml",
      "{workspaceRoot}/mvnw",
      "{workspaceRoot}/mvnw.cmd",
      "{workspaceRoot}/.mvn/**/*",
      "{workspaceRoot}/apps/**/pom.xml",
      "{workspaceRoot}/apps/**/src/**/*"
    ],
    "typescriptSources": [
      "{projectRoot}/src/**/*",
      "{projectRoot}/tsconfig.json",
      "{projectRoot}/tsdown.config.ts",
      "{workspaceRoot}/tsdown.config.ts"
    ]
  },
  "targetDefaults": {
    "compile": {
      "cache": true,
      "inputs": ["javaMonorepoSources"],
      "outputs": ["{projectRoot}/target"]
    },
    "test": {
      "cache": true,
      "inputs": ["javaMonorepoSources"],
      "outputs": ["{projectRoot}/target"]
    },
    "package": {
      "cache": true,
      "inputs": ["javaMonorepoSources"],
      "outputs": ["{projectRoot}/target"]
    },
    "build": {
      "cache": true,
      "inputs": ["default", "typescriptSources"],
      "outputs": ["{projectRoot}/dist"]
    },
    "lint": {
      "cache": true,
      "inputs": ["default", "typescriptSources"],
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint {projectRoot}/src"
      }
    },
    "format": {
      "cache": true,
      "inputs": ["default", "typescriptSources"],
      "outputs": ["{projectRoot}/src/**/*"]
    }
  },
  "analytics": true,
  "nxCloudId": "6a29d3fb3765f3e608af78f0"
}
