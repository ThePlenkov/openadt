{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "tui": {
    "enabled": false
  },
  "namedInputs": {
    "sharedGlobals": ["{workspaceRoot}/.github/workflows/ci.yml"],
    "default": ["sharedGlobals"],
    "javaSources": [
      "{projectRoot}/pom.xml",
      "{projectRoot}/src/**/*",
      "{projectRoot}/mvnw",
      "{projectRoot}/mvnw.cmd",
      "{projectRoot}/.mvn/**/*"
    ],
    "javaMonorepoSources": [
      "{workspaceRoot}/pom.xml",
      "{workspaceRoot}/mvnw",
      "{workspaceRoot}/mvnw.cmd",
      "{workspaceRoot}/.mvn/**/*",
      "{workspaceRoot}/apps/**/pom.xml",
      "{workspaceRoot}/apps/**/src/**/*"
    ]
  },
  "targetDefaults": {
    "compile": {
      "cache": true,
      "inputs": ["javaMonorepoSources"],
      "outputs": ["{projectRoot}/target"]
    },
    "test": {
      "cache": true,
      "inputs": ["javaMonorepoSources"],
      "outputs": ["{projectRoot}/target"]
    },
    "package": {
      "cache": true,
      "inputs": ["javaMonorepoSources"],
      "outputs": ["{projectRoot}/target"]
    }
  },
  "analytics": true
}
