{
  "name": "e2e-ai-testing-skill",
  "version": "1.0.0",
  "description": "Abstract AI-first testing framework for MCP scenarios",
  "type": "module",
  "bin": {
    "e2e-agent": "./cli.js"
  },
  "scripts": {
    "build": "tsc"
  },
  "files": [
