{
  "name": "openadt-cli",
  "root": "apps/openadt-cli",
  "sourceRoot": "apps/openadt-cli/src/main/java",
  "projectType": "application",
  "metadata": {
    "mavenProject": "org.openadt:openadt"
  },
  "targets": {
    "compile": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "openadt-config:compile",
        "openadt-sap-adt:compile",
        "openadt-bootstrap:compile"
      ],
      "options": {
        "command": "node scripts/mvnw-runner.mjs -q compile -pl apps/openadt-cli -am -Pdistribution -Dopenadt.distribution=true -f pom.xml && bun run scripts/dev-runtime-classpath.ts",
        "cwd": "{workspaceRoot}"
      },
      "cache": true,
      "inputs": ["javaMonorepoSources"],
      "outputs": ["{projectRoot}/target"]
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["package"],
      "options": {
        "command": "node scripts/mvnw-runner.mjs -q test -pl apps/openadt-cli -am -Pdistribution -Dopenadt.distribution=true -f pom.xml",
        "cwd": "{workspaceRoot}"
      },
      "cache": true,
      "inputs": ["javaMonorepoSources"],
      "outputs": ["{projectRoot}/target"]
    },
    "package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/mvnw-runner.mjs -q package -pl apps/openadt-cli -am -Pdistribution -Dopenadt.distribution=true -DskipTests -f pom.xml",
        "cwd": "{workspaceRoot}"
      },
      "cache": true,
      "inputs": ["javaMonorepoSources"],
      "outputs": ["{projectRoot}/target"]
    },
    "ensure-dev-jar": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "bun run scripts/ensure-dev-jar.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "dependsOn": ["compile", "ensure-dev-jar"],
      "cache": false,
      "options": {
        "command": "bun run scripts/nx-openadt.ts",
        "cwd": "{workspaceRoot}",
        "forwardAllArgs": true
      }
    },
    "run-sdk": {
      "executor": "nx:run-commands",
      "dependsOn": ["compile", "ensure-dev-jar"],
      "cache": false,
      "options": {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/openadt-sdk.ps1",
        "cwd": "apps/openadt-cli",
        "forwardAllArgs": true
      }
    }
  }
}
