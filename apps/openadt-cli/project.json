{
  "name": "openadt-cli",
  "root": "apps/openadt-cli",
  "sourceRoot": "apps/openadt-cli/src/main/java",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["javaSources"],
      "outputs": ["{projectRoot}/target"],
      "options": {
        "command": "mvnw -q -DskipTests package",
        "cwd": "apps/openadt-cli"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "cache": true,
      "inputs": ["javaSources"],
      "outputs": ["{projectRoot}/target"],
      "options": {
        "command": "mvnw -q test",
        "cwd": "apps/openadt-cli"
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "cache": false,
      "options": {
        "command": "bun run ../../scripts/nx-openadt.ts",
        "cwd": "apps/openadt-cli",
        "forwardAllArgs": true
      }
    },
    "run-sdk": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "cache": false,
      "options": {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/openadt-sdk.ps1",
        "cwd": "apps/openadt-cli",
        "forwardAllArgs": true
      }
    }
  }
}
