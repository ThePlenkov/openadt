{
  "name": "openadt-cli",
  "root": "apps/openadt-cli",
  "sourceRoot": "apps/openadt-cli/src/main/java",
  "projectType": "application",
  "metadata": {
    "mavenProject": "org.openadt:openadt"
  },
  "targets": {
    "compile": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "openadt-config:package",
        "openadt-sap-adt:package",
        "openadt-bootstrap:package"
      ],
      "options": {
        "command": "node scripts/mvnw-runner.mjs -q compile -pl apps/openadt-cli -am -Pdistribution -f pom.xml",
        "cwd": "{workspaceRoot}"
      },
      "cache": true,
      "inputs": [
        "javaMonorepoSources"
      ],
      "outputs": [
        "{projectRoot}/target"
      ]
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "package"
      ],
      "options": {
        "command": "node scripts/mvnw-runner.mjs -q test -pl apps/openadt-cli -am -Pdistribution -f pom.xml",
        "cwd": "{workspaceRoot}"
      },
      "cache": true,
      "inputs": [
        "javaMonorepoSources"
      ],
      "outputs": [
        "{projectRoot}/target"
      ]
    },
    "package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/mvnw-runner.mjs -q package -pl apps/openadt-cli -am -Pdistribution -DskipTests -f pom.xml",
        "cwd": "{workspaceRoot}"
      },
      "cache": true,
      "inputs": [
        "javaMonorepoSources"
      ],
      "outputs": [
        "{projectRoot}/target"
      ]
    },
    "run": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "package"
      ],
      "cache": false,
      "options": {
        "command": "bun run ../../scripts/nx-openadt.ts",
        "cwd": "apps/openadt-cli",
        "forwardAllArgs": true
      }
    },
    "run-sdk": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "package"
      ],
      "cache": false,
      "options": {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/openadt-sdk.ps1",
        "cwd": "apps/openadt-cli",
        "forwardAllArgs": true
      }
    }
  }
}